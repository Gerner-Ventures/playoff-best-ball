# Local dev database (docker compose up -d): dev on 5434, test on 5433
DATABASE_URL="postgresql://pbb:pbb@localhost:5434/pbb_dev"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth providers — leave empty to disable a provider in dev
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Email (magic links). Empty = links are logged to the server console instead.
RESEND_API_KEY=""
# Optional: override the magic-link From address
MAGIC_LINK_FROM_EMAIL=""
# Optional: override the notifications From address
NOTIFY_FROM_EMAIL=""

# Twilio SMS ("text me when I'm on the clock"). Empty = SMS logs to the dev console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Web Push. Generate once with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@playoffbestball.com"

# Inngest (durable draft timers). Empty in dev — run `npx inngest-cli@latest dev` alongside
# `npm run dev` to exercise pick clocks locally. Set both in production (Vercel integration).
# Set INNGEST_DEV=1 when running without inngest-cli (disables signing key requirement).
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Platform admin emails (comma-separated) — unlocks /admin
ADMIN_EMAILS=""
