{
  "name": "playoff-best-ball",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "dotenv -e .env.test -- vitest run",
    "test:watch": "dotenv -e .env.test -- vitest",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:push:test": "dotenv -e .env.test -- prisma db push",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "db:seed:players": "dotenv -e .env -- tsx prisma/seed-players-cli.ts",
    "db:seed:players:test": "dotenv -e .env.test -- tsx prisma/seed-players-cli.ts",
    "mock:week": "dotenv -e .env -- tsx scripts/mock-week.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.23",
    "inngest": "^4.12.1",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "stripe": "^22.3.1",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
