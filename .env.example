# Local dev database (docker compose up -d): dev on 5434, test on 5433
DATABASE_URL="postgresql://pbb:pbb@localhost:5434/pbb_dev"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth providers — leave empty to disable a provider in dev
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Email (magic links). Empty = links are logged to the server console instead.
RESEND_API_KEY=""
# Optional: override the magic-link From address
MAGIC_LINK_FROM_EMAIL=""
# Optional: override the notifications From address
NOTIFY_FROM_EMAIL=""
